# ── AI provider (pick ONE) ──────────────────────────────────────────
AI_PROVIDER=gemini

# Google AI Studio key — AIza... (standard) or AQ.... (new auth key)
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_aiza_key_here

# OpenRouter (only if AI_PROVIDER=openrouter) — starts with sk-or-
# OPENROUTER_API_KEY=sk-or-v1-...

# ── Direct Gemini models (AI_PROVIDER=gemini) ───────────────────────
#
# Image enhance / translate (image IN → image OUT):
#   gemini-2.5-flash-image          ← default (Nano Banana)
#   gemini-3.1-flash-image          ← Nano Banana 2
#   gemini-3.1-flash-lite-image     ← cheaper
#   gemini-3-pro-image              ← highest quality
# GEMINI_ENHANCE_IMAGE_MODEL=gemini-2.5-flash-image   ← Enhance tool only (cheaper)
# GEMINI_IMAGE_MODEL=gemini-3-pro-image               ← Translate image (best quality)
#
# OCR / text translation (image IN → text OUT):
#   gemini-2.5-pro                  ← default (best for Cyrillic OCR + translation)
#   gemini-2.5-flash                ← faster / cheaper
# GEMINI_VISION_MODEL=gemini-2.5-pro

# ── OpenRouter models (AI_PROVIDER=openrouter) ────────────────────────
# Use full OpenRouter slugs (provider/model). Imagen, Gemini image, GPT image, etc.
#
# Gemini family (shown as "Gemini" in UI):
# OPENROUTER_GEMINI_VISION_MODEL=google/gemini-2.5-pro
# OPENROUTER_GEMINI_ENHANCE_IMAGE_MODEL=google/gemini-2.5-flash-image-preview
# OPENROUTER_GEMINI_IMAGE_MODEL=google/gemini-3-pro-image-preview
#
# OpenAI family (shown as "OpenAI" in UI):
# OPENROUTER_OPENAI_VISION_MODEL=openai/gpt-4o
# OPENROUTER_OPENAI_ENHANCE_IMAGE_MODEL=openai/gpt-image-1-mini
# OPENROUTER_OPENAI_IMAGE_MODEL=openai/gpt-image-2
#   Other image models: openai/gpt-image-1, openai/gpt-image-1-mini, openai/gpt-5.4-image-2
#   Uses OpenRouter Image API (POST /api/v1/images) with input_references for scan editing
# OPENROUTER_OPENAI_IMAGE_FALLBACK_TO_GEMINI=true
#
# Optional fallback chains (comma-separated, tried in order):
# OPENROUTER_GEMINI_IMAGE_MODELS=google/gemini-2.5-flash-image-preview,google/imagen-3.0-generate-002
# OPENROUTER_OPENAI_IMAGE_MODELS=openai/gpt-image-1
#
# Legacy (maps to Gemini family image model):
# IMAGE_MODEL=google/gemini-2.5-flash-image-preview
#
# UI: which families appear in the header switch (when OpenRouter is active)
# OPENROUTER_UI_FAMILIES=gemini,openai
# OPENROUTER_DEFAULT_FAMILY=gemini

# OpenRouter HTTP-Referer header (optional)
# APP_URL=http://localhost:5173

PORT=3001

# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
